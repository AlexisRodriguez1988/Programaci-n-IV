public SaldoJFrame() {
        initComponents();
        
        Conexion conn = new Conexion();
        Connection con = null;
        
        try {
            con = conn.getConnection();
           
            PreparedStatement ps = con.prepareStatement("SELECT saldo FROM CUENTA WHERE idcuenta = 1");
            ResultSet rs = ps.executeQuery();
            
            if (rs.next()) {
               
                String saldoActual = String.valueOf(rs.getDouble("saldo"));
                jtfMonto.setText(saldoActual);
            } else {
                jtfMonto.setText("0.00");
            }
            
        } catch (SQLException e) {
            JOptionPane.showMessageDialog(this, "Error de SQL: " + e.getMessage());
        } catch (Exception e) {
            JOptionPane.showMessageDialog(this, "Error: " + e.getMessage());
        } finally {
           
            try { if (con != null) con.close(); } catch (SQLException ex) {}
        }
    
}
